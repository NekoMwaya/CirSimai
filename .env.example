# ─── Local Development ────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored; never commit real keys.

# Google Gemini API key  (used by api/ai-chat.js serverless function)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Frontend (VITE_ prefix = exposed to the browser build) ──────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

VITE_STRIPE_PRO_URL=https://buy.stripe.com/...
VITE_STRIPE_TEAM_URL=https://buy.stripe.com/...

VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/...
VITE_CALENDLY_URL=https://calendly.com/your-handle/30min
